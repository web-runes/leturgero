{
	"name": "@leturgero/cli",
	"version": "0.1.1",
	"description": "Web fonts, made simple.",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"bin": "./dist/index.js",
	"exports": {
		".": {
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"logo.txt",
		"types.d.ts"
	],
	"scripts": {
		"dev": "tsc --build --force --watch",
		"build": "tsc --build --force",
		"test": "node --test --test-reporter=spec \"test/**/*.test.ts\"",
		"start": "node ./dist/index.js"
	},
	"keywords": [
		"cli",
		"fonts"
	],
	"author": "contact@florian-lefebvre.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/web-runes/leturgero.git",
		"directory": "packages/cli"
	},
	"bugs": "https://github.com/web-runes/leturgero/issues",
	"homepage": "https://leturgero.web-runes.dev",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.4",
		"typescript": "7.0.1-rc"
	},
	"dependencies": {
		"@capsizecss/unpack": "^4.0.1",
		"@clack/prompts": "^1.6.0",
		"fuse.js": "^7.4.2",
		"gunshi": "~0.35.1",
		"unifont": "~0.7.4"
	}
}
